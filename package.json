{
  "name": "graphlink-social",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "test": "node --test",
    "seed": "node src/server.js --seed-only",
    "seed:graph": "node src/server.js --seed-only",
    "report": "python scripts/generate_report.py",
    "neo4j:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-neo4j.ps1",
    "neo4j:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-neo4j.ps1",
    "neo4j:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-neo4j.ps1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cytoscape": "^3.32.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "neo4j-driver": "^5.28.1",
    "swagger-ui-dist": "^5.21.0",
    "zod": "^3.25.4"
  },
  "devDependencies": {
    "supertest": "^7.1.0",
    "vitest": "^3.1.3"
  }
}
